APP_NAME='Server-API'
APP_ENV='local'
APP_DEBUG=false

MAX_COROUTINE=100000

#是否启用http服务
ENABLE_HTTP=true
HTTP_PORT=9504

#是否启用ws服务
ENABLE_WS=false
WS_PORT=9505
WEBSOCKET_COMPRESSION=true

#是否启用crontab
ENABLE_CRONTAB=false

#默认时区设置
DATE_DEFAULT_TIMEZONE='Asia/Shanghai'
#可用时区列表见：
#https://www.php.net/manual/zh/timezones.php

#管理后台模块
ADMIN_MODULE_NAME='Admin'

#控制器总后缀
ROUTE_SUFFIX='.do'

#API是否开启数据加密
API_DATA_CRYPT=false
#API是否开启接口鉴权
API_CHECK_SIGN=false
#接口签名密钥(原硬编码在 SignConf,已迁此;生产请用真实环境变量覆盖并轮换——旧值已进 git 历史)
SIGN_KEY='gh^R^RG^R%4e'

#http协议类型
HTTP_SCHEME="http"

#MySql
DB_DRIVER=mysql
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=''
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE='test'
DB_USERNAME='root'
DB_PASSWORD='root'
DB_MIN_CONNECTION=1

#Redis(tls模式则在地址前加：tls://)
REDIS_HOST=localhost
REDIS_AUTH=
REDIS_USER=
REDIS_PORT=6379
REDIS_DB=0
REDIS_MIN_CONNECTION=1

#RabbitMq
AMQP_ENABLE=false
AMQP_OPEN_SSL=true
AMQP_HOST=localhost
AMQP_PORT=5672
AMQP_USER=admin
AMQP_PASSWORD=admin
AMQP_VHOST=/
AMQP_MIN_CONNECTION=1
AMQP_MAX_CONNECTION=10
AMQP_CONNECTION=20
AMQP_MAX_IDLE_CHANNELS=1000

#接口加密 RSA 密钥对(2048,base64(PEM);生产请替换为自有密钥)
RSA_PRIVATE_
RSA_PUBLIC_
